## Updater for .dotfiles
# oh-my-zsh
cp ~/.zshrc ./
cp -r ~/.oh-my-zsh ./
zip -r .oh-my-zsh.zip ./.oh-my-zsh
rm -rf .oh-my-zsh/
git add . && git commit -S -m "bump" && git push origin master
